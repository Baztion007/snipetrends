# ─── Database ──────────────────────────────────────────────────────────────
# Local dev: a SQLite file (no adapter needed, works out of the box).
DATABASE_URL="file:./db/custom.db"

# Production (Turso / libSQL): the app auto-detects "libsql://" URLs and
# uses the @prisma/adapter-libsql driver adapter (Cloudflare-compatible).
# Create a Turso DB: https://turso.tech
#   turso db create shopaffiliate
#   turso db show shopaffiliate --url      → DATABASE_URL
#   turso db tokens create shopaffiliate   → DATABASE_AUTH_TOKEN
# DATABASE_URL="libsql://shopaffiliate-<you>.turso.io"
# DATABASE_AUTH_TOKEN="eyJ..."

# ─── Security ──────────────────────────────────────────────────────────────
# Strong random secret for signing admin session JWTs. Generate with:
#   openssl rand -base64 32
# NEVER commit the real value — set it in your deployment platform's secrets.
SESSION_SECRET="change-me-to-a-long-random-secret-32+chars"

# ─── Public site URL ───────────────────────────────────────────────────────
# Your production origin (no trailing slash). Used for sitemap, robots, OG tags.
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# ─── Cloudflare (optional, for @opennextjs/cloudflare deployment) ──────────
# These are set automatically by the Cloudflare Pages/Workers runtime.
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
