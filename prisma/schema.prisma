// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // libSQL (Turso) is wire-compatible with SQLite. Use "sqlite" as the
  // provider and the @prisma/adapter-libsql driver adapter in lib/db.ts.
  // For local dev, DATABASE_URL can still be a file: path (plain SQLite).
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Admin users authenticate with username + password (bcrypt-style scrypt hash).
// This replaces the prior password-only verification.
model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  name         String?
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Single-row key/value store for site-wide affiliate configuration.
// Holds the Amazon Associate tag, site name, disclosure text, etc. — all
// editable from the admin "Settings" panel so you never hardcode them.
model SiteSetting {
  id    String @id @default("singleton")
  // Your Amazon Associates tracking ID, e.g. "yourstore-20".
  // Appended to every affiliate URL as ?tag=<associateTag>.
  amazonAssociateTag String  @default("")
  // Optional base URL for affiliate links (defaults to https://www.amazon.com).
  amazonBaseUrl      String  @default("https://www.amazon.com")
  // Display name of the site (used in footer / disclosure).
  siteName           String  @default("ShopAffiliate")
  // Contact email shown in the footer / admin.
  contactEmail       String  @default("hello@shopaffiliate.example")
  // Custom affiliate disclosure override (empty = use default).
  disclosureOverride String?
  socialTwitter      String?
  socialInstagram    String?
  socialYoutube      String?
  socialGithub       String?
  updatedAt          DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  icon      String?
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id            String   @id @default(cuid())
  title         String
  description   String?
  // SQLite cannot store lists as primitives, so gallery images are a JSON string array.
  image         String
  images        String?
  price         Float
  compareAtPrice Float?
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  brand         String?
  badge         String?  // "deal" | "bestseller" | "new" | null
  featured      Boolean  @default(false)
  stock         Int      @default(0)
  affiliateUrl  String
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  clicks        AffiliateClick[]
  priceAlerts   PriceAlert[]
  collections   CollectionItem[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([categoryId])
  @@index([featured])
  @@index([badge])
}

model AffiliateClick {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  referrer  String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

// Newsletter subscribers captured from the footer signup form.
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// ─── Feature 1: Price-drop alerts ─────────────────────────────────────────
// Visitors subscribe to be notified when a product's price drops.
// The "triggeredPrice" is set when an admin/cron updates a product's price
// below the subscriber's threshold — used to send the notification email.
model PriceAlert {
  id             String   @id @default(cuid())
  email          String
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  threshold      Float    // notify when price drops below this
  triggered      Boolean  @default(false)
  triggeredAt    DateTime?
  createdAt      DateTime @default(now())

  @@index([productId])
  @@index([email])
  @@index([triggered])
}

// ─── Feature 2: Blog / content pages ──────────────────────────────────────
// SEO-focused articles for category landing content ("Best Wireless Headphones").
model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   // markdown body
  coverImage  String?
  category    String?  // e.g. "guides", "reviews", "deals"
  tags        String?  // comma-separated
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([slug])
  @@index([category])
}

// ─── Feature 3: Gift guides / curated collections ─────────────────────────
// Themed product lists ("Back to School", "Gifts Under $50", etc.).
model Collection {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  coverImage  String?
  // "guide" (gift guide) | "edit" (editor's pick) | "seasonal" (holiday)
  type        String   @default("guide")
  published   Boolean  @default(false)
  items       CollectionItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([type])
}

model CollectionItem {
  id           String     @id @default(cuid())
  collectionId String
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  sortOrder    Int        @default(0)
  note         String?    // why this product is in the collection

  @@index([collectionId])
  @@index([productId])
}
